# Copy to `.env` at this repo root (never commit `.env`).
# Used by `pnpm dev:first-layer`, `pnpm --filter @theworld/dev-console demo:live`, `pnpm test:first-layer-real`.

OPENAI_API_KEY=
# OpenAI-compatible root; final request is `{baseUrl}/chat/completions`.
# LongCat: include `/v1` — see https://api.longcat.chat/openai/v1/chat/completions
OPENAI_BASE_URL=https://api.longcat.chat/openai/v1
OPENAI_MODEL=LongCat-Flash-Chat

# ── Troubleshooting LLM `fetch failed` / LLM_UNAVAILABLE ─────────────────────
# The server prefers IPv4 for outbound HTTPS (see cli.ts). If your provider still fails:
#   - Try another OpenAI-compatible base URL (e.g. api.openai.com) and matching model.
#   - Or clear the API key in Settings / env to use MockLLMProvider for local smoke tests.
# Node also accepts: NODE_OPTIONS=--dns-result-order=ipv4first
#
# Default LLM HTTP client uses IPv4-only connections (fixes TLS resets to some hosts).
# To use Node's default dual-stack fetch: THEWORLD_LLM_CONNECT_FAMILY=0
# Fallback compatibility: OPENKIN_LLM_CONNECT_FAMILY also works during the rename window.
# THEWORLD_LLM_CONNECT_FAMILY=4
