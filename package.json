{
  "name": "openkin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "dev:server": "node --env-file=.env --import=tsx/esm packages/server/src/cli.ts",
    "dev:first-layer": "pnpm --filter @openkin/dev-console start",
    "demo:first-layer:interactive": "pnpm --filter @openkin/dev-console demo:interactive",
    "demo:first-layer:mock": "pnpm --filter @openkin/dev-console demo:mock",
    "demo:first-layer:scenarios": "pnpm --filter @openkin/dev-console scenarios",
    "lint:docs": "node scripts/lint-docs.mjs",
    "lint:architecture": "node scripts/lint-architecture.mjs",
    "lint:workspace": "node scripts/lint-workspace.mjs",
    "test:core": "pnpm --filter @openkin/core check",
    "test:server": "node scripts/test-server.mjs",
    "test:sdk": "node scripts/test-sdk.mjs",
    "test:channels": "node scripts/test-channels.mjs",
    "test:first-layer-real": "node scripts/test-first-layer-real.mjs",
    "test:scenarios": "pnpm demo:first-layer:scenarios",
    "test:first-layer-audit": "pnpm --filter @openkin/dev-console first-layer-audit",
    "test:first-layer-real-audit": "pnpm --filter @openkin/dev-console real-audit",
    "test:tools": "node scripts/test-tools.mjs",
    "test:mcp": "node scripts/test-mcp.mjs",
    "test:skills": "node scripts/test-skills.mjs",
    "test:self-management": "node scripts/test-self-management.mjs",
    "verify": "pnpm lint:docs && pnpm lint:architecture && pnpm lint:workspace && pnpm check && pnpm test:scenarios && pnpm test:first-layer-audit && pnpm test:server && pnpm test:sdk && pnpm test:channels && pnpm test:tools && pnpm test:mcp && pnpm test:skills && pnpm test:self-management"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
