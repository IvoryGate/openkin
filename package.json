{
  "name": "theworld",
  "private": true,
  "version": "0.2.0-skeleton",
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "lint:docs": "node scripts/lint-docs.mjs",
    "lint:architecture": "node scripts/lint-architecture.mjs",
    "lint:workspace": "node scripts/lint-workspace.mjs",
    "test:scenarios": "pnpm --filter @theworld/dev-console scenarios",
    "test:first-layer-audit": "pnpm --filter @theworld/dev-console first-layer-audit",
    "test:server": "node scripts/lib/pending.mjs test:server",
    "test:sdk": "node scripts/lib/pending.mjs test:sdk",
    "test:channels": "node scripts/lib/pending.mjs test:channels",
    "test:tools": "node scripts/lib/pending.mjs test:tools",
    "test:mcp": "node scripts/lib/pending.mjs test:mcp",
    "test:skills": "node scripts/lib/pending.mjs test:skills",
    "test:self-management": "node scripts/lib/pending.mjs test:self-management",
    "test:sandbox": "node scripts/lib/pending.mjs test:sandbox",
    "test:persistence": "node scripts/lib/pending.mjs test:persistence",
    "test:auth-health": "node scripts/lib/pending.mjs test:auth-health",
    "test:session-message": "node scripts/lib/pending.mjs test:session-message",
    "test:observability": "node scripts/lib/pending.mjs test:observability",
    "test:agent-config": "node scripts/lib/pending.mjs test:agent-config",
    "test:scheduler": "node scripts/lib/pending.mjs test:scheduler",
    "test:introspection": "node scripts/lib/pending.mjs test:introspection",
    "test:approval": "node scripts/lib/pending.mjs test:approval",
    "test:context-descriptors": "node scripts/lib/pending.mjs test:context-descriptors",
    "test:multimodal": "node scripts/lib/pending.mjs test:multimodal",
    "test:l4-shell-map": "node scripts/lib/pending.mjs test:l4-shell-map",
    "test:l4-onboarding": "node scripts/lib/pending.mjs test:l4-onboarding",
    "test:l4-context": "node scripts/lib/pending.mjs test:l4-context",
    "test:l4-memory": "node scripts/lib/pending.mjs test:l4-memory",
    "test:l4-approval": "node scripts/lib/pending.mjs test:l4-approval",
    "test:l4-background": "node scripts/lib/pending.mjs test:l4-background",
    "test:l4-plan": "node scripts/lib/pending.mjs test:l4-plan",
    "test:l4-polish": "node scripts/lib/pending.mjs test:l4-polish",
    "verify": "pnpm lint:docs && pnpm lint:architecture && pnpm lint:workspace && pnpm check && pnpm build && node scripts/verify/index.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
