{
  "name": "theworld",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "dev:server": "node --env-file=.env --import=tsx/esm packages/server/src/cli.ts",
    "theworld": "node --import=tsx/esm packages/cli/src/index.ts",
    "world": "node --import=tsx/esm packages/cli/src/index.ts",
    "chat": "node --import=tsx/esm packages/cli/src/index.ts chat",
    "dev:first-layer": "pnpm --filter @theworld/dev-console start",
    "demo:first-layer:interactive": "pnpm --filter @theworld/dev-console demo:interactive",
    "demo:first-layer:mock": "pnpm --filter @theworld/dev-console demo:mock",
    "demo:first-layer:scenarios": "pnpm --filter @theworld/dev-console scenarios",
    "lint:docs": "node scripts/lint-docs.mjs",
    "lint:architecture": "node scripts/lint-architecture.mjs",
    "lint:workspace": "node scripts/lint-workspace.mjs",
    "test:core": "pnpm --filter @theworld/core check",
    "test:server": "node scripts/test-server.mjs",
    "test:sdk": "node scripts/test-sdk.mjs",
    "test:channels": "node scripts/test-channels.mjs",
    "test:first-layer-real": "node scripts/test-first-layer-real.mjs",
    "test:scenarios": "pnpm demo:first-layer:scenarios",
    "test:first-layer-audit": "pnpm --filter @theworld/dev-console first-layer-audit",
    "test:first-layer-real-audit": "pnpm --filter @theworld/dev-console real-audit",
    "test:tools": "node scripts/test-tools.mjs",
    "test:mcp": "node scripts/test-mcp.mjs",
    "test:skills": "node scripts/test-skills.mjs",
    "test:self-management": "node scripts/test-self-management.mjs",
    "test:sandbox": "node scripts/test-sandbox.mjs",
    "test:persistence": "node scripts/test-persistence.mjs",
    "test:auth-health": "node scripts/test-auth-health.mjs",
    "test:session-message": "node scripts/test-session-message-api.mjs",
    "test:run-cancel": "node --import=tsx/esm scripts/run-run-cancel-smoke.ts",
    "test:observability": "node scripts/test-observability.mjs",
    "test:agent-config": "node scripts/test-agent-config.mjs",
    "test:scheduler": "node scripts/test-scheduler.mjs",
    "test:introspection": "node scripts/test-introspection.mjs",
    "test:session-runs": "node scripts/test-session-runs.mjs",
    "test:event-plane": "node scripts/test-event-plane.mjs",
    "test:approval": "node scripts/test-approval.mjs",
    "test:context-descriptors": "node scripts/test-context-descriptors.mjs",
    "test:multimodal": "node scripts/test-multimodal.mjs",
    "test:l4-shell-map": "node --import=tsx/esm scripts/test-l4-shell-map.ts",
    "test:l4-onboarding": "node scripts/test-l4-onboarding.mjs",
    "test:l4-context": "node scripts/test-l4-context.mjs",
    "test:l4-memory": "node scripts/test-l4-memory.mjs",
    "test:l4-approval": "node scripts/test-l4-approval.mjs",
    "test:l4-background": "node scripts/test-l4-background.mjs",
    "test:l4-plan": "node scripts/test-l4-plan.mjs",
    "test:l4-polish": "node scripts/test-l4-polish.mjs",
    "test:project-cli": "node scripts/test-project-cli.mjs",
    "test:cli-shell": "node scripts/test-project-cli.mjs",
    "dev:web-console": "pnpm --filter @theworld/web-console dev",
    "build:web-console": "pnpm --filter @theworld/web-console build",
    "verify": "pnpm lint:docs && pnpm lint:architecture && pnpm lint:workspace && pnpm check && pnpm build:web-console && pnpm test:scenarios && pnpm test:first-layer-audit && pnpm test:server && pnpm test:persistence && pnpm test:auth-health && pnpm test:session-message && pnpm test:run-cancel && pnpm test:observability && pnpm test:agent-config && pnpm test:sdk && pnpm test:project-cli && pnpm test:channels && pnpm test:tools && pnpm test:mcp && pnpm test:skills && pnpm test:self-management && pnpm test:sandbox && pnpm test:scheduler && pnpm test:l4-shell-map && pnpm test:l4-onboarding && pnpm test:l4-context && pnpm test:l4-memory && pnpm test:l4-approval && pnpm test:l4-background && pnpm test:l4-plan && pnpm test:l4-polish && pnpm test:introspection && pnpm test:session-runs && pnpm test:event-plane && pnpm test:approval && pnpm test:context-descriptors && pnpm test:multimodal"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
